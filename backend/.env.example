# ─── Required ───────────────────────────────────────────────────────
# Get your API key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ─── Optional: Vertex AI for higher quotas on side calls ────────────
# Set to true to use Vertex AI for image/quiz/search generation
# (Live API always uses API key — native audio is API-key-only)
USE_VERTEX_AI=false
GCP_PROJECT=your-gcp-project-id
GCP_LOCATION=us-central1
# Optional planner model (defaults to gemini-2.5-pro for deep reasoning)
PLANNER_MODEL=gemini-2.5-pro

# ─── Optional: Profile persistence backend ───────────────────────────
# local = JSON files in backend/profiles
# firestore = Google Cloud Firestore collection named "learners"
PROFILE_STORE=local
# Optional explicit project for Firestore client. Falls back to GCP_PROJECT.
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
